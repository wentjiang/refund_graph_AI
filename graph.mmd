---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	parse_user_intent(parse_user_intent)
	risk_policy_check(risk_policy_check)
	negotiate_customer_care(negotiate_customer_care)
	execute_refund(execute_refund)
	generate_final_notification(generate_final_notification)
	__end__([<p>__end__</p>]):::last
	__start__ --> parse_user_intent;
	execute_refund --> generate_final_notification;
	negotiate_customer_care --> execute_refund;
	parse_user_intent --> risk_policy_check;
	risk_policy_check -.-> execute_refund;
	risk_policy_check -.-> negotiate_customer_care;
	generate_final_notification --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
